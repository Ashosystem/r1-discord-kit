# Discord bot token — from https://discord.com/developers/applications → your app → Bot → Token
BOT_TOKEN=your_bot_token_here

# Comma-separated list of Discord server (guild) IDs to expose in the app.
# Get a server ID: enable Developer Mode in Discord (Settings → Advanced),
# then right-click the server icon and choose "Copy Server ID".
# NOTE: your bot must already be added to each server listed here.
GUILD_IDS=123456789012345678,987654321098765432

# Port to run the backend on (default: 3002)
PORT=3002

# Optional: ngrok reserved hostname only (no https://). run-ngrok-tunnel.sh passes --url https://YOUR_HOST
# NGROK_DOMAIN=juicy-vicissitudinous-lachlan.ngrok-free.dev
# ngrok account authtoken — required for tunnels (or run `ngrok config add-authtoken` once on this machine)
# NGROK_AUTHTOKEN=

# Optional: shared secret token. If set, the web UI and WebSocket
# connections must supply this token. Leave blank to disable auth.
R1_AUTH_TOKEN=

# Google AI Studio (Gemini API) — Genre button rationale + Discord embed text.
# Keys: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Override model ID if needed (default matches AI Studio previews).
GEMINI_MODEL=gemini-3-flash-preview

# Optional: copy your current public tunnel URL for Creations (?backend=...).
# Works with ngrok (e.g. *.ngrok-free.app), Cloudflare Try, or a fixed domain.
# Not read by server.js. When scripts/run-ngrok-tunnel.sh or run-cloudflared-quick-tunnel.sh +
# systemd learns a new URL, this line and `.tunnel-url` are rewritten when applicable.
